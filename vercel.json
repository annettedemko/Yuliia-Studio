{
  "buildCommand": "npm run build:ssg",
  "outputDirectory": "dist",
  "framework": null,
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/icoone-laser", "destination": "/de/icoone-laser-muenchen", "permanent": true },
    { "source": "/redtouchpro", "destination": "/de/redtouch-laser-muenchen", "permanent": true },
    { "source": "/manikuere-pedikuere", "destination": "/de/manikuere-pedikuere-muenchen", "permanent": true },

    { "source": "/de/deka-geraeteverkauf", "destination": "/de/services", "permanent": true },
    { "source": "/de/redtouch-pro", "destination": "/de/services", "permanent": true },
    { "source": "/de/motus-pro", "destination": "/de/services", "permanent": true },
    { "source": "/de/motus-ax", "destination": "/de/services", "permanent": true },
    { "source": "/de/physiq360", "destination": "/de/services", "permanent": true },
    { "source": "/de/again-cos", "destination": "/de/services", "permanent": true },
    { "source": "/de/deka", "destination": "/de/services", "permanent": true },
    { "source": "/de/deka-day", "destination": "/de/services", "permanent": true },
    { "source": "/de/deka-anna", "destination": "/de/services", "permanent": true },
    { "source": "/de/deka-lera", "destination": "/de/services", "permanent": true },
    { "source": "/de/deka-liudmila", "destination": "/de/services", "permanent": true },

    { "source": "/ru/deka-geraeteverkauf", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/redtouch-pro", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/motus-pro", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/motus-ax", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/physiq360", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/again-cos", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/deka", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/deka-day", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/deka-anna", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/deka-lera", "destination": "/ru/services", "permanent": true },
    { "source": "/ru/deka-liudmila", "destination": "/ru/services", "permanent": true },

    { "source": "/deka-geraeteverkauf", "destination": "/de/services", "permanent": true },
    { "source": "/redtouch-pro", "destination": "/de/services", "permanent": true },
    { "source": "/motus-pro", "destination": "/de/services", "permanent": true },
    { "source": "/motus-ax", "destination": "/de/services", "permanent": true },
    { "source": "/physiq360", "destination": "/de/services", "permanent": true },
    { "source": "/again-cos", "destination": "/de/services", "permanent": true },
    { "source": "/deka", "destination": "/de/services", "permanent": true },
    { "source": "/deka-day", "destination": "/de/services", "permanent": true },
    { "source": "/deka-anna", "destination": "/de/services", "permanent": true },
    { "source": "/deka-lera", "destination": "/de/services", "permanent": true },
    { "source": "/deka-liudmila", "destination": "/de/services", "permanent": true },
    { "source": "/kopie-deka-day-anna", "destination": "/de/services", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/de/:path*", "destination": "/de/:path*/index.html" },
    { "source": "/ru/:path*", "destination": "/ru/:path*/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path*\\.(jpg|jpeg|png|gif|ico|svg|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(self), payment=(self \"https://checkout.stripe.com\")"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.alteg.io https://www.googletagmanager.com https://www.google-analytics.com https://va.vercel-scripts.com https://*.elfsight.com https://elfsightcdn.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://*.alteg.io https://*.elfsight.com https://elfsightcdn.com; font-src 'self' https://*.alteg.io; img-src 'self' data: https: blob:; connect-src 'self' https://knmompemjlboqzwcycwe.supabase.co https://*.supabase.co https://www.google-analytics.com https://*.google-analytics.com https://va.vercel-scripts.com https://*.alteg.io https://*.elfsight.com https://elfsightcdn.com https://api.stripe.com; frame-src https://www.google.com https://maps.google.com https://maps.googleapis.com https://*.alteg.io https://*.elfsight.com https://js.stripe.com https://checkout.stripe.com; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.alteg.io https://checkout.stripe.com"
        }
      ]
    }
  ]
}

# Yuliia Cheporska Beauty Studio - Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase (REQUIRED)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Tag Manager (optional - loads with Consent Mode v2)
VITE_GTM_ID=

# Google Analytics Measurement ID (also needed for Altegio built-in GA4 integration)
VITE_GA_MEASUREMENT_ID=
